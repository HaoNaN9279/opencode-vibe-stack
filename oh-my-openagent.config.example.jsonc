{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "agents": {
    // ---- Orchestrators ----
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 32000 },
      "ultrawork": {
        "model": "deepseek/deepseek-v4-pro",
        "reasoningEffort": "xhigh",
        "thinking": { "type": "enabled", "budgetTokens": 64000 }
      },
      "permission": {
      }
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
      }
    },

    // ---- Planner ----
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 16000 },
      "permission": {
      }
    },

    // ---- Read-only Advisors ----
    "oracle": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 32000 },
      "permission": {
      }
    },
    "metis": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.3,
      "reasoningEffort": "medium",
      "permission": {
      }
    },
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
      }
    },

    // ---- Explorers ----
    "librarian": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.3,
      "reasoningEffort": "low",
      "maxTokens": 4096,
      "permission": {
      }
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "maxTokens": 4096,
      "permission": {
      }
    },
    "multimodal-looker": {
      "model": "ollama/qwen3.5:9b",
      "temperature": 0.4,
      "maxTokens": 8192,
      "permission": {
      }
    },

    // ---- Executors ----
    "sisyphus-junior": {
      "permission": {
      }
    },
    "build": {
      "permission": {
        "edit": "allow",
        "task": "deny"
      }
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 64000 }
    },
    "deep": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 32000 }
    },
    "visual-engineering": {
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.7,
      "reasoningEffort": "medium",
      "prompt_append": "Use shadcn/ui components and Tailwind CSS. Focus on responsive design and accessibility."
    },
    "artistry": {
      "model": "opencode/big-pickle",
      "temperature": 1.0
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "low"
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.6
    }
  },
  "background_task": {
    "providerConcurrency": {
      "deepseek": 5,
      "opencode": 5,
      "ollama": 2
    },
    "modelConcurrency": {
      "deepseek/deepseek-v4-pro": 2,
      "deepseek/deepseek-v4-flash": 5,
      "opencode/deepseek-v4-flash-free": 5,
      "opencode/nemotron-3-super-free": 3,
      "opencode/big-pickle": 3,
      "ollama/qwen3.5:9b": 2
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "model_fallback": true
  },
  "agent_order": ["sisyphus", "prometheus", "atlas", "hephaestus"],
  "disabled_agents": [],
  "disabled_skills": []
}

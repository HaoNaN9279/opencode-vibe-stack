{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "permissions": {
    "edit": "ask",
    "web": "allow",
    "run": "ask",
    
    "bash": {
      "allow": [
        "ls", "ll", "la", "pwd", "cd", "echo", "cat", "head", "tail", "less", "more",
        "wc", "grep", "find", "which", "whereis", "whoami", "id", "uname", "hostname",
        "date", "uptime", "free", "df", "du", "ps", "top", "htop", "netstat", "ss",
        "ip", "ifconfig", "ping", "curl -I", "wget --spider", "dig", "nslookup",
        
        "git status", "git log", "git branch", "git diff", "git show", "git remote -v",
        "git config --list", "git stash list", "git tag", "git describe",
        "npm list", "npm outdated", "npm view", "yarn list", "pnpm list",
        "docker ps", "docker images", "docker volume ls", "docker network ls",
        "docker compose ps", "kubectl get", "kubectl describe", "helm list",
        
        "clear", "history", "alias", "env", "printenv", "set", "export",
        "mkdir -p", "touch", "cp -n", "mv -n", "ln -s"
      ],
      
      "ask": [
        "rm", "rmdir", "mv", "cp", "chmod", "chown", "chgrp", "mkdir",
        "sed", "awk", "tr", "cut", "sort", "uniq", "tee", ">>", ">",
        
        "git add", "git commit", "git push", "git pull", "git merge", "git rebase",
        "git checkout", "git switch", "git reset", "git revert", "git stash",
        "git stash pop", "git branch -d", "git tag -d", "git remote add",
        
        "npm install", "npm uninstall", "npm update", "npm run",
        "yarn add", "yarn remove", "yarn upgrade", "yarn run",
        "pnpm add", "pnpm remove", "pnpm update", "pnpm run",
        "pip install", "pip uninstall", "pip update", "cargo install",
        
        "docker run", "docker build", "docker pull", "docker push",
        "docker stop", "docker start", "docker restart", "docker rm", "docker rmi",
        "docker compose up", "docker compose down", "docker compose restart",
        
        "sudo", "su", "systemctl", "service", "apt", "apt-get", "yum", "dnf",
        "brew", "snap", "flatpak", "useradd", "userdel", "groupadd", "groupdel",
        
        "wget", "curl", "tar", "zip", "unzip", "gzip", "gunzip",
        "ssh", "scp", "rsync", "nc", "telnet", "bash", "sh", "zsh"
      ],
      
      "deny": [
        "rm -rf /", "rm -rf /*", "rm -rf ~", "rm -rf ~/*",
        "dd if=/dev/zero", "dd if=/dev/random", "mkfs", "mkswap",
        "fdisk", "parted", "gdisk", "cfdisk", "sfdisk",
        
        "shutdown", "reboot", "halt", "poweroff", "init 0", "init 6",
        "systemctl poweroff", "systemctl reboot", "systemctl halt",
        
        "chmod 777 /", "chmod -R 777 /", "chown -R root:root /",
        "mv /etc", "rm -rf /etc", "rm -rf /bin", "rm -rf /sbin",
        "rm -rf /usr", "rm -rf /var", "rm -rf /boot",
        
        "nmap", "masscan", "hping3", "nc -l", "nc -lvp",
        "iptables -F", "ufw disable", "firewalld stop",
        
        ":(){ :|:& };:", "fork bomb", "eval", "exec", "source",
        "sudo su", "sudo -i", "sudo -s", "su root", "passwd root"
      ]
    }
  },
  
  "security": {
    "enforce_ask_for_pipes": true,
    "enforce_ask_for_wildcards": true,
    "always_ask_for_sudo": true,
    "command_timeout": 30,
    "max_command_length": 1024
  },
    
  "agents": {
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      },
      "ultrawork": {
        "model": "deepseek/deepseek-v4-pro",
        "reasoningEffort": "xhigh",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 64000
        }
      }
    },
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 16000
      }
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium"
    },
    "hephaestus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 64000
      }
    },
    "hermes": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "oracle": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    "metis": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.3,
      "reasoningEffort": "medium"
    },
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium"
    },
    "librarian": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.3,
      "reasoningEffort": "low",
      "maxTokens": 4096
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "maxTokens": 4096
    },
    "multimodal-looker": {
      "model": "ollama/qwen3.5:9b",
      "temperature": 0.4,
      "maxTokens": 8192
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 64000
      }
    },
    "deep": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    "visual-engineering": {
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.7,
      "reasoningEffort": "medium",
      "prompt_append": "Use shadcn/ui components and Tailwind CSS. Focus on responsive design and accessibility."
    },
    "artistry": {
      "model": "opencode/big-pickle",
      "temperature": 1.0
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "low"
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.6
    }
  },
  "background_task": {
    "providerConcurrency": {
      "deepseek": 5,
      "opencode": 5,
      "ollama": 2
    },
    "modelConcurrency": {
      "deepseek/deepseek-v4-pro": 2,
      "deepseek/deepseek-v4-flash": 5,
      "opencode/deepseek-v4-flash-free": 5,
      "opencode/nemotron-3-super-free": 3,
      "opencode/big-pickle": 3,
      "ollama/qwen3.5:9b": 2
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "model_fallback": true
  },
  "agent_order": ["hermes", "sisyphus", "prometheus", "atlas"],
  "disabled_agents": ["hephaestus"],
  "disabled_skills": []
}

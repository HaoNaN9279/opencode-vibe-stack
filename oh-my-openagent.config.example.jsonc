{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // ============================================================
  // Agent Permissions Design Principles:
  //
  // 每种 agent 的 permission 根据其角色职能设计：
  //
  //   orchestrator 类 (sisyphus, atlas, hephaestus):
  //     全部 allow — 需要执行所有操作协调工作
  //
  //   planner 类 (prometheus):
  //     全部 allow — 需要编辑计划文件、运行命令调研
  //
  //   read-only advisor 类 (oracle, metis, momus):
  //     edit/bash/task → deny, webfetch → allow
  //     只读咨询分析，但需要联网查资料
  //
  //   explorer 类 (librarian):
  //     edit/task → deny, bash/webfetch → allow
  //     需要 git/gh 命令克隆仓库查代码
  //
  //   explorer 类 (explore, multimodal-looker):
  //     全部 deny — 仅用内置 grep/lsp/read 工具
  //
  //   executor 类 (sisyphus-junior):
  //     全部 allow — 需要完整执行能力
  //
  //   default 类 (build):
  //     edit/bash/webfetch → allow, task → deny
  //     OpenCode 默认 agent，不需要创建子任务
  // ============================================================

  "agents": {
    // ---- Orchestrators ----
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 32000 },
      "ultrawork": {
        "model": "deepseek/deepseek-v4-pro",
        "reasoningEffort": "xhigh",
        "thinking": { "type": "enabled", "budgetTokens": 64000 }
      },
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow",
        "external_directory": "allow"
      }
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow",
        "external_directory": "allow"
      }
    },
    "hephaestus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 64000 },
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow",
        "external_directory": "allow"
      }
    },

    // ---- Planner ----
    "prometheus": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 16000 },
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow"
      }
    },

    // ---- Read-only Advisors ----
    "oracle": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 32000 },
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": "deny"
      }
    },
    "metis": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.3,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": "deny"
      }
    },
    "momus": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "medium",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": "deny"
      }
    },

    // ---- Explorers ----
    "librarian": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.3,
      "reasoningEffort": "low",
      "maxTokens": 4096,
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "webfetch": "allow",
        "task": "deny"
      }
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.2,
      "reasoningEffort": "low",
      "maxTokens": 4096,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "task": "deny"
      }
    },
    "multimodal-looker": {
      "model": "ollama/qwen3.5:9b",
      "temperature": 0.4,
      "maxTokens": 8192,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny",
        "task": "deny"
      }
    },

    // ---- Executors ----
    "sisyphus-junior": {
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow",
        "external_directory": "allow"
      }
    },
    "build": {
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "deny"
      }
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 64000 }
    },
    "deep": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.15,
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 32000 }
    },
    "visual-engineering": {
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.7,
      "reasoningEffort": "medium",
      "prompt_append": "Use shadcn/ui components and Tailwind CSS. Focus on responsive design and accessibility."
    },
    "artistry": {
      "model": "opencode/big-pickle",
      "temperature": 1.0
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.1,
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.2,
      "reasoningEffort": "low"
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "deepseek/deepseek-v4-flash",
      "temperature": 0.6
    }
  },
  "background_task": {
    "providerConcurrency": {
      "deepseek": 5,
      "opencode": 5,
      "ollama": 2
    },
    "modelConcurrency": {
      "deepseek/deepseek-v4-pro": 2,
      "deepseek/deepseek-v4-flash": 5,
      "opencode/deepseek-v4-flash-free": 5,
      "opencode/nemotron-3-super-free": 3,
      "opencode/big-pickle": 3,
      "ollama/qwen3.5:9b": 2
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "model_fallback": true
  },
  "agent_order": ["sisyphus", "prometheus", "atlas", "hephaestus"],
  "disabled_agents": [],
  "disabled_skills": []
}

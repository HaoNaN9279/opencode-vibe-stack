{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "default_agent": "hermes",
  "permission": {
    "bash": {
      "git commit": "ask",
      "git add": "ask",
      "git delete": "ask",
      "git clone": "ask",
      "rm -rf": "deny",
      "chmod": "deny",
      "chown": "deny",
      "netcat": "deny",
      "ssh": "deny",
      "scp": "deny",
      "telnet": "deny",
      "dd": "deny",
      "mkfs": "deny",
      "mount": "deny",
      "umount": "deny",
      "reboot": "deny",
      "shutdown": "deny",
      "iptables": "deny",
      "ufw": "deny",
      "chroot": "deny"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://172.18.160.1:11434/v1"
      },
      "models": {
        "qwen3.5:9b": {
          "name": "qwen3.5:9b"
        }
      }
    }
  },
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        "ts",
        "tsx",
        "js",
        "jsx",
        "mjs",
        "cjs"
      ]
    }
  },
  "instructions": [
    "~/.config/opencode/rules/*.md"
  ],
  "skills": {
    "paths": [
      "skills"
    ]
  }
}

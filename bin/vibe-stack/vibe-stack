#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VIBE_STACK_HOME="$(cd "$SCRIPT_DIR/../.." && pwd)"

# Allow env override
VIBE_STACK_HOME="${VIBE_STACK_HOME:-$VIBE_STACK_HOME}"
export VIBE_STACK_HOME

if ! command -v uv &>/dev/null; then
    echo "[ERROR] uv not found. Install: https://astral.sh/uv" >&2
    exit 1
fi

exec uv run --project "$VIBE_STACK_HOME" python -m vibe_stack.cli "$@"

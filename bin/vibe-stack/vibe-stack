#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VIBE_STACK_HOME="$(dirname "$(dirname "$SCRIPT_DIR"))"

# Allow env override
VIBE_STACK_HOME="${VIBE_STACK_HOME:-$VIBE_STACK_HOME}"

if ! command -v uv &>/dev/null; then
    echo "[ERROR] uv not found. Install: https://astral.sh/uv" >&2
    exit 1
fi

cd "$VIBE_STACK_HOME"
exec uv run python -m vibe_stack.cli "$@"
